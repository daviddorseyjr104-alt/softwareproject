# ─────────────────────────────────────────────────────────────
# Kaizen Candidate Finder — environment configuration
# Copy this file to ".env" and fill in real values.
# NEVER commit the real .env (it is gitignored).
# ─────────────────────────────────────────────────────────────

# --- Server ---
PORT=3000
# development | test | anything-else. ANYTHING not "development"/"test" is treated as production,
# so a host that simply forgets to set this gets the strict checks rather than an open console.
NODE_ENV=development
# Where durable state (settings.json, jobs.json, client-edited pool) is stored.
# On a host, point this at a persistent disk (e.g. /var/data).
DATA_DIR=

# --- Secrets (host secret store in production; never committed) ---
# The app REFUSES to boot without all three. To run open locally on purpose, set
# ALLOW_INSECURE_DEV=1 (npm run demo does this for you).
#
# Shared secret the GoHighLevel/Flowsa webhook must send as an "x-webhook-secret" HEADER.
# A "?secret=" query value is NOT accepted — URLs leak into access logs, proxy logs, browser
# history, and the Referer header. This secret authorizes SENDING only: it cannot read candidate
# PII (job detail is admin-only). Generate: openssl rand -hex 32
WEBHOOK_SECRET=
# Password for the /admin settings page. This one credential guards the API keys, live sending,
# and every candidate's personal email — make it long. Minimum 12 chars; 20+ recommended.
ADMIN_PASSWORD=
# Signs admin sessions AND encrypts API keys at rest (AES-256-GCM, scrypt-derived key).
# data/settings.json is an offline oracle for guesses, so use high entropy, not a passphrase:
#   openssl rand -hex 32
SECRET_KEY=
# Set to 1 to allow booting WITHOUT the secrets above. Local development only — never on a host.
# ALLOW_INSECURE_DEV=

# --- Spend / load limits ---
# Each run fans out to Apollo, paid SalesQL lookups, GitHub, and one Claude call per candidate.
# Requests past MAX_CONCURRENT_RUNS + MAX_QUEUED_RUNS get 503 instead of a 202 that quietly spends.
# MAX_CONCURRENT_RUNS=2
# MAX_QUEUED_RUNS=8

# ─────────────────────────────────────────────────────────────
# The API keys below can be set here OR entered in the /admin settings page (stored encrypted).
# Whichever is present is used; the UI value wins if both are set.
# ─────────────────────────────────────────────────────────────

# --- Apollo.io (candidate DISCOVERY: title + location -> people + LinkedIn URLs) ---
# API key from Apollo (Settings -> Integrations -> API). Required.
APOLLO_API_KEY=
# Wide net: how many people to DISCOVER per role (cheap search). We pre-rank these for free
# and enrich only the best. Bigger = better odds of finding the top candidate.
DISCOVER_LIMIT=100
# Finalists: how many top-ranked candidates to ENRICH (the paid SalesQL step = 1 credit each).
MAX_CANDIDATES=25
# Apollo seniorities to target, comma-separated. Options: owner,founder,c_suite,partner,vp,head,director,manager,senior,entry,intern
APOLLO_SENIORITIES=manager,director,senior

# --- SalesQL (ENRICHMENT: LinkedIn URL -> personal email) ---
# Bearer token from SalesQL. Required.
SALESQL_API_KEY=
# Only push candidates whose SalesQL email type is "personal". Set to "false" to also allow professional emails.
PERSONAL_EMAILS_ONLY=true

# --- GitHub deep-profile enrichment (real engineering signal: repos, stars, languages) ---
# Optional token. Works WITHOUT one (lower rate limit); a token lifts it sharply.
GITHUB_TOKEN=
# Set "false" to skip GitHub enrichment entirely.
ENRICH_GITHUB=true

# --- Instantly.ai (OUTREACH: create campaign + add leads) ---
# API v2 Bearer key from Instantly (Settings -> Integrations -> API). Required.
INSTANTLY_API_KEY=
# Timezone + sending window for auto-created campaigns.
INSTANTLY_TIMEZONE=America/New_York
INSTANTLY_SENDING_FROM=09:00
INSTANTLY_SENDING_TO=17:00
# Optional: an existing Instantly campaign ID to clone sequence/settings from. Leave blank to create bare campaigns.
INSTANTLY_TEMPLATE_CAMPAIGN_ID=

# --- AI fit scoring (Claude) ---
# Anthropic API key. If blank, candidate scoring falls back to DETERMINISTIC-only (no AI fit score).
ANTHROPIC_API_KEY=
# Reasoning effort per candidate: low | medium | high | xhigh | max. Low is plenty for scoring.
AI_EFFORT=low

# --- Candidate scoring + matching (used by `npm run match`) ---
# Only candidates scoring >= this (0-100) get matched and emailed.
SCORE_THRESHOLD=60
# Relative weights of each signal in the composite score (need not sum to 1).
WEIGHT_AI=0.4
WEIGHT_SKILLS=0.25
WEIGHT_SENIORITY=0.2
WEIGHT_PEDIGREE=0.15

# --- Behavior ---
# If "true", the pipeline runs discovery+enrichment but does NOT create anything in Instantly (safe testing).
DRY_RUN=false
# Company names that force DRY_RUN regardless of the flag above (per the blueprint's "Test Company" guidance).
TEST_COMPANY_NAMES=Test Company,Test,Demo
LOG_LEVEL=info

# --- Safety & automation ---
# Don't re-email anyone contacted within this many days (cross-run dedup). 0 = off.
DEDUPE_WINDOW_DAYS=0
# Automated sourcing: re-run the pool PREVIEW every N hours for review. Never auto-sends. 0 = off.
SCHEDULE_HOURS=0
