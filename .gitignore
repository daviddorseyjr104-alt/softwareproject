node_modules/
.env
.env.local
*.log
logs/
.DS_Store

# Runtime state: API keys (encrypted), candidate jobs, the contacted-emails audit trail, and
# the do-not-contact list — all either secret or PII. Deny the directory and re-admit only the
# committed .example.json samples, so a new state file is private by default rather than by
# remembering to add a line here. Keep this rule in sync with .dockerignore.
data/*
!data/*.example.json
